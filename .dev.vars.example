# .dev.vars — Cloudflare Workers local secrets (DO NOT COMMIT TO GIT)
# These mirror the secrets you'll set via `wrangler secret put` for production
# Copy this file as .dev.vars and fill in your real values

MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/nyaree?retryWrites=true&w=majority

# Upstash Redis (HTTP-based, works on CF Workers)
UPSTASH_REDIS_REST_URL=https://YOUR_UPSTASH_URL.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# Better Auth
BETTER_AUTH_SECRET=GENERATE_WITH_openssl_rand_-hex_32_HERE

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Resend (https://resend.com)
RESEND_API_KEY=re_YOUR_RESEND_KEY

# Razorpay (https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET

# Cloudinary (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY

# Store config
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Nyaree
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
ADMIN_EMAIL=rishika@buynyaree.com
STORE_EMAIL=hello@buynyaree.com
